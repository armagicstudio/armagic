<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anni Cafe - Menu</title>
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        :root {
            --bg-dark: #0b1118;
            --card-bg: #111d27;
            --primary-green: #00d26a;
            --text-gray: #a0aab4;
            --text-white: #ffffff;
            --overlay: rgba(0, 0, 0, 0.9);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-white);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 15px;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 450px;
        }

        /* --- Header --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .brand h1 { margin: 0; font-size: 20px; }
        .brand p { margin: 0; font-size: 10px; color: var(--text-gray); letter-spacing: 1px; }

        .cart-wrapper {
            background: #1a2632;
            padding: 10px;
            border-radius: 50%;
            position: relative;
            cursor: pointer;
            border: 1px solid #2d3741;
        }
        .cart-badge {
            position: absolute;
            top: -4px; right: -4px;
            background: var(--primary-green);
            color: #000;
            font-size: 9px;
            font-weight: bold;
            width: 16px; height: 16px;
            border-radius: 50%;
            display: none; align-items: center; justify-content: center;
        }

        /* --- Categories --- */
        .categories {
            display: flex;
            gap: 8px;
            margin-bottom: 15px;
            overflow-x: auto;
            scrollbar-width: none;
        }
        .categories::-webkit-scrollbar { display: none; }
        .cat-btn {
            background: #1a2632;
            border: 1px solid #2d3741;
            color: var(--text-gray);
            padding: 6px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            white-space: nowrap;
        }
        .cat-btn.active { background: var(--primary-green); color: #000; border-color: var(--primary-green); }

        /* --- Small Item Card --- */
        .menu-card {
            background: var(--card-bg);
            border-radius: 15px;
            padding: 12px;
            margin-bottom: 10px;
            display: flex;
            gap: 12px;
            border: 1px solid #1f2e3d;
            align-items: center;
        }

        .img-box {
            background: #081a1a;
            min-width: 70px;
            height: 70px;
            border-radius: 12px;
            display: flex;
            align-items: center; justify-content: center;
        }
        .img-box img { width: 45px; height: auto; }

        .details { flex: 1; }
        .details h3 { margin: 0; font-size: 15px; font-weight: 600; }
        .price { color: var(--primary-green); float: right; font-size: 15px; font-weight: bold; }
        .desc { 
            color: var(--text-gray); 
            font-size: 11px; 
            margin: 4px 0; 
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .label { font-size: 9px; color: var(--text-gray); text-transform: uppercase; }

        /* --- Small Buttons & Counter --- */
        .btns { display: flex; gap: 8px; margin-top: 8px; height: 32px; }
        .btn {
            flex: 1; border-radius: 15px; border: none; font-size: 11px;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            text-decoration: none;
        }
        .btn-ar { background: rgba(0, 210, 106, 0.05); color: var(--primary-green); border: 1px solid rgba(0, 210, 106, 0.2); }
        .btn-add { background: #0b3d26; color: var(--primary-green); border: 1px solid rgba(0, 210, 106, 0.2); }

        .qty-controller {
            display: none;
            flex: 1;
            background: #0b3d26;
            border-radius: 15px;
            border: 1px solid var(--primary-green);
            align-items: center;
            justify-content: space-around;
            color: var(--primary-green);
            font-weight: bold;
            font-size: 12px;
        }
        .qty-controller button {
            background: none; border: none; color: var(--primary-green);
            font-size: 16px; cursor: pointer;
        }

        /* --- Admin Route (Preserved) --- */
        .admin-add-btn {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; background: rgba(255, 255, 255, 0.03);
            border: 1px dashed #2d3741; color: var(--text-gray);
            text-decoration: none; padding: 10px; border-radius: 12px;
            margin-bottom: 15px; font-size: 13px;
        }

        /* --- Cart Modal --- */
        #cartOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--overlay); display: none; justify-content: center; align-items: flex-end;
            z-index: 1000;
        }
        .cart-modal {
            background: var(--card-bg); width: 100%; max-width: 450px;
            border-radius: 20px 20px 0 0; padding: 20px;
            max-height: 70vh; overflow-y: auto;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div class="brand">
            <h1>Anni Cafe</h1>
            <p>DINE-IN ORDERING</p>
        </div>
        <div class="cart-wrapper" onclick="toggleCart(true)">
            🛒 <div id="cartBadge" class="cart-badge">0</div>
        </div>
    </header>

    <div class="categories">
        <button class="cat-btn active" onclick="filterMenu('All', this)">All</button>
        <button class="cat-btn" onclick="filterMenu('Appetizers', this)">Appetizers</button>
        <button class="cat-btn" onclick="filterMenu('Main Course', this)">Main Course</button>
        <button class="cat-btn" onclick="filterMenu('Desserts', this)">Desserts</button>
        <button class="cat-btn" onclick="filterMenu('Beverages', this)">Beverages</button>
    </div>

    <a href="/menu/new" class="admin-add-btn">
        <span style="color: var(--primary-green);">+</span> Add Item
    </a>

    <div id="menuList">
        <% items.forEach(item => { %>
        <div class="menu-card" data-category="<%= item.category %>" data-name="<%= item.name %>">
            <div class="img-box">
                <img src="<%= item.poster %>" alt="<%= item.name %>">
            </div>
            <div class="details">
                <span class="price">₹<%= item.price %></span>
                <h3><%= item.name %></h3>
                <p class="desc"><%= item.description %></p>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span class="label"><%= item.category %></span>
                </div>
                <div class="btns">
                    <a href="<%= item.model %>" class="btn btn-ar">View AR</a>
                    <button class="btn btn-add add-trigger" onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">Add</button>
                    <div class="qty-controller">
                        <button onclick="updateCart('<%= item.name %>', <%= item.price %>, -1)">-</button>
                        <span class="qty-count">0</span>
                        <button onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">+</button>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>

<div id="cartOverlay" onclick="if(event.target == this) toggleCart(false)">
    <div class="cart-modal">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
            <h2 style="margin:0; font-size:18px;">Your Order</h2>
            <span onclick="toggleCart(false)" style="cursor:pointer; color:var(--text-gray);">✕</span>
        </div>
        <div id="cartItemsList"></div>
        <div style="display:flex; justify-content:space-between; margin-top:15px; font-weight:bold; border-top:1px solid #1f2e3d; padding-top:10px;">
            <span>Total:</span>
            <span id="totalPrice" style="color: var(--primary-green);">₹0</span>
        </div>
        <button style="background:var(--primary-green); color:black; width:100%; padding:12px; border-radius:10px; border:none; margin-top:15px; font-weight:bold; cursor:pointer;" onclick="confirmOrder()">Confirm Order</button>
    </div>
</div>

<script>
    let cart = [];

    function updateCart(name, price, change) {
        const itemIndex = cart.findIndex(item => item.name === name);
        if (itemIndex > -1) {
            cart[itemIndex].qty += change;
            if (cart[itemIndex].qty <= 0) cart.splice(itemIndex, 1);
        } else if (change > 0) {
            cart.push({ name, price, qty: 1 });
        }
        syncUI();
    }

    function syncUI() {
        let totalCount = 0;
        let totalPrice = 0;

        document.querySelectorAll('.menu-card').forEach(card => {
            const name = card.getAttribute('data-name');
            const item = cart.find(i => i.name === name);
            const addBtn = card.querySelector('.add-trigger');
            const qtyCtrl = card.querySelector('.qty-controller');
            const qtyLabel = card.querySelector('.qty-count');

            if (item) {
                addBtn.style.display = 'none';
                qtyCtrl.style.display = 'flex';
                qtyLabel.innerText = item.qty;
            } else {
                addBtn.style.display = 'flex';
                qtyCtrl.style.display = 'none';
            }
        });

        const list = document.getElementById('cartItemsList');
        list.innerHTML = cart.length === 0 ? "<p style='font-size:13px; color:var(--text-gray);'>Empty</p>" : "";
        
        cart.forEach(item => {
            totalCount += item.qty;
            totalPrice += (item.price * item.qty);
            list.innerHTML += `
                <div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #1f2e3d; font-size:14px;">
                    <span>${item.name} x ${item.qty}</span>
                    <span style="color:var(--primary-green)">₹${item.price * item.qty}</span>
                </div>`;
        });

        const badge = document.getElementById('cartBadge');
        badge.innerText = totalCount;
        badge.style.display = totalCount > 0 ? "flex" : "none";
        document.getElementById('totalPrice').innerText = "₹" + totalPrice;
    }

    function toggleCart(show) { document.getElementById('cartOverlay').style.display = show ? "flex" : "none"; }

    function confirmOrder() {
        if(cart.length === 0) return;
        alert("Order placed! Total: " + document.getElementById('totalPrice').innerText);
        cart = []; syncUI(); toggleCart(false);
    }

    function filterMenu(category, btn) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.menu-card').forEach(card => {
            const cat = card.getAttribute('data-category');
            card.style.display = (category === 'All' || cat === category) ? 'flex' : 'none';
        });
    }
</script>

</body>
</html>