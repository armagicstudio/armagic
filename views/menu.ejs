<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anni Cafe - Menu</title>
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        :root {
            --bg-dark: #070b10;
            /* Updated card background to blend better with logo's earth tones */
            --card-bg: #141a22; 
            --primary-green: #00c853;
            --text-gray: #8b949e;
            --text-white: #ffffff;
            --border: #1f2937;
            --overlay: rgba(0, 0, 0, 0.9);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-white);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 15px;
            display: flex;
            justify-content: center;
        }

        .container { width: 100%; max-width: 480px; }

        /* --- Updated Header for Logo --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            background: #ffffff; /* White background for the logo bar */
            padding: 10px;
            border-radius: 16px;
            border: 1px solid #eaeaea; /* Light border */
        }
        
        .logo-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        /* Set the logo height as requested */
        .logo-container img {
            height: 100px;
            width: auto;
        }

        .cart-icon {
            background: #f4f4f4; /* Light background for the cart on the white header */
            padding: 10px;
            border-radius: 50%;
            position: relative;
            border: 1px solid #eaeaea;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .badge {
            position: absolute; top: -4px; right: -4px;
            background: var(--primary-green); color: black;
            font-size: 11px; font-weight: bold; padding: 3px 6px; border-radius: 12px;
        }

        /* --- Admin Route (Preserved) --- */
        .admin-add-btn {
            display: flex; align-items: center; justify-content: center;
            gap: 8px; background: rgba(255, 255, 255, 0.03);
            border: 1px dashed var(--border); color: var(--text-gray);
            text-decoration: none; padding: 12px; border-radius: 12px;
            margin-bottom: 20px; font-size: 14px;
        }

        /* --- Compact Menu Card --- */
        .menu-card {
            background: var(--card-bg);
            border-radius: 16px;
            padding: 12px;
            margin-bottom: 12px;
            display: flex;
            gap: 12px;
            border: 1px solid var(--border);
        }

        .img-container {
            background: #0d1117;
            min-width: 65px;
            height: 65px;
            border-radius: 12px;
            display: flex;
            align-items: center; justify-content: center;
        }
        .img-container img { width: 40px; height: auto; }

        .details { flex: 1; display: flex; flex-direction: column; }
        
        .header-row { display: flex; justify-content: space-between; align-items: flex-start; }
        .details h3 { margin: 0; font-size: 16px; font-weight: 600; }
        .price { color: var(--primary-green); font-size: 16px; font-weight: bold; }

        .desc { 
            color: var(--text-gray); 
            font-size: 11px; 
            margin: 4px 0; 
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .footer-row { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 8px; }
        .cat-label { font-size: 10px; color: var(--text-gray); text-transform: uppercase; }

        /* --- Action Buttons (Preserved) --- */
        .btn-group { display: flex; gap: 8px; align-items: center; }
        
        .btn-ar {
            background: rgba(0, 200, 83, 0.1);
            color: var(--primary-green);
            border: 1px solid rgba(0, 200, 83, 0.2);
            padding: 5px 12px;
            border-radius: 15px;
            font-size: 11px;
            text-decoration: none;
        }

        .action-box { width: 90px; height: 30px; display: flex; }
        
        .btn-add {
            width: 100%; background: #0b2e1b; color: var(--primary-green);
            border: 1px solid #144b2d; border-radius: 15px;
            font-size: 11px; font-weight: bold; cursor: pointer;
        }

        .qty-ctrl {
            display: none; width: 100%; background: #0b2e1b;
            border-radius: 15px; border: 1px solid var(--primary-green);
            align-items: center; justify-content: space-around;
            color: var(--primary-green); font-weight: bold; font-size: 13px;
        }
        .qty-ctrl button { background: none; border: none; color: var(--primary-green); font-size: 18px; cursor: pointer; }

        /* --- Cart Modal --- */
        #cartOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--overlay); display: none; justify-content: center; align-items: flex-end;
            z-index: 1000;
        }
        .cart-modal {
            background: var(--card-bg); width: 100%; max-width: 480px;
            border-radius: 24px 24px 0 0; padding: 20px;
            max-height: 80vh; overflow-y: auto;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div class="logo-container">
            <img src="<%= logoPath %>" alt="Anni Cafe Logo">
        </div>
        <div class="cart-icon" onclick="toggleCart(true)">
            🛒 <span id="badge" class="badge" style="display:none">0</span>
        </div>
    </header>

    <h2 style="margin: 0 0 15px 0;">Our Menu</h2>

    <a href="/menu/new" class="admin-add-btn">
        <span style="color: var(--primary-green);">+</span> Add Menu Item
    </a>

    <div id="menu">
        <% items.forEach(item => { %>
        <div class="menu-card" data-category="<%= item.category %>" data-name="<%= item.name %>">
            <div class="img-container">
                <img src="<%= item.poster %>" alt="">
            </div>
            <div class="details">
                <div class="header-row">
                    <h3><%= item.name %></h3>
                    <span class="price">₹<%= item.price %></span>
                </div>
                <p class="desc"><%= item.description %></p>
                <div class="footer-row">
                    <span class="cat-label"><%= item.category %></span>
                    <div class="btn-group">
                        <a href="<%= item.model %>" class="btn-ar">AR</a>
                        <div class="action-box">
                            <button class="btn-add" onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">Add</button>
                            <div class="qty-ctrl">
                                <button onclick="updateCart('<%= item.name %>', <%= item.price %>, -1)">-</button>
                                <span class="count">0</span>
                                <button onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">+</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>

<div id="cartOverlay" onclick="if(event.target == this) toggleCart(false)">
    <div class="cart-modal">
        <div style="display:flex; justify-content:space-between; margin-bottom:15px;">
            <h2 style="margin:0; font-size:18px;">Review Order</h2>
            <span onclick="toggleCart(false)" style="cursor:pointer; color:var(--text-gray);">✕</span>
        </div>
        <div id="cartItemsList"></div>
        <div style="display:flex; justify-content:space-between; margin-top:20px; font-weight:bold; border-top:1px solid var(--border); padding-top:15px;">
            <span>Total:</span>
            <span id="totalPrice" style="color: var(--primary-green);">₹0</span>
        </div>
        <button style="background:var(--primary-green); color:black; width:100%; padding:14px; border-radius:12px; border:none; margin-top:20px; font-weight:bold; cursor:pointer;" onclick="confirmOrder()">Confirm Order</button>
    </div>
</div>

<script>
    let cart = [];

    function updateCart(name, price, delta) {
        const idx = cart.findIndex(i => i.name === name);
        if (idx > -1) {
            cart[idx].qty += delta;
            if (cart[idx].qty <= 0) cart.splice(idx, 1);
        } else if (delta > 0) {
            cart.push({ name, price, qty: 1 });
        }
        syncUI();
    }

    function syncUI() {
        let totalCount = 0;
        let totalPrice = 0;

        document.querySelectorAll('.menu-card').forEach(card => {
            const name = card.getAttribute('data-name');
            const item = cart.find(i => i.name === name);
            const btn = card.querySelector('.btn-add');
            const ctrl = card.querySelector('.qty-ctrl');
            const count = card.querySelector('.count');

            if (item) {
                btn.style.display = 'none';
                ctrl.style.display = 'flex';
                count.innerText = item.qty;
            } else {
                btn.style.display = 'block';
                ctrl.style.display = 'none';
            }
        });

        const list = document.getElementById('cartItemsList');
        list.innerHTML = cart.length === 0 ? "<p style='color:var(--text-gray)'>No items added.</p>" : "";
        
        cart.forEach(item => {
            totalCount += item.qty;
            totalPrice += (item.price * item.qty);
            list.innerHTML += `
                <div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--border);">
                    <span>${item.name} (x${item.qty})</span>
                    <span style="color:var(--primary-green)">₹${item.price * item.qty}</span>
                </div>`;
        });

        const b = document.getElementById('badge');
        b.innerText = totalCount;
        b.style.display = totalCount > 0 ? 'block' : 'none';
        document.getElementById('totalPrice').innerText = "₹" + totalPrice;
    }

    function toggleCart(show) { document.getElementById('cartOverlay').style.display = show ? "flex" : "none"; }

    function confirmOrder() {
        if(cart.length === 0) return;
        alert("Order placed! Total: " + document.getElementById('totalPrice').innerText);
        cart = []; syncUI(); toggleCart(false);
    }
</script>

</body>
</html>