<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Anni Cafe - Menu</title>
    <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        :root {
            --bg-dark: #0b1118;
            --card-bg: #111d27;
            --primary-green: #00d26a;
            --text-gray: #a0aab4;
            --text-white: #ffffff;
            --overlay: rgba(0, 0, 0, 0.9);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-white);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 500px;
        }

        /* --- Header & Cart --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .brand h1 { margin: 0; font-size: 24px; }
        .brand p { margin: 0; font-size: 11px; color: var(--text-gray); letter-spacing: 1px; }

        .cart-wrapper {
            background: #1a2632;
            padding: 12px;
            border-radius: 50%;
            position: relative;
            cursor: pointer;
            border: 1px solid #2d3741;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--primary-green);
            color: #000;
            font-size: 10px;
            font-weight: bold;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
        }

        /* --- Category Navigation --- */
        .categories {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
            overflow-x: auto;
            white-space: nowrap;
            scrollbar-width: none;
        }
        .categories::-webkit-scrollbar { display: none; }

        .cat-btn {
            background: #1a2632;
            border: 1px solid #2d3741;
            color: var(--text-gray);
            padding: 8px 22px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
        }

        .cat-btn.active {
            background: var(--primary-green);
            color: #000;
        }

        /* --- Admin Route Preserved --- */
        .admin-add-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.03);
            border: 2px dashed #2d3741;
            color: var(--text-gray);
            text-decoration: none;
            padding: 15px;
            border-radius: 20px;
            margin-bottom: 20px;
            font-weight: bold;
        }

        /* --- Menu Card Styles --- */
        .menu-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 15px;
            display: flex;
            gap: 15px;
            border: 1px solid #1f2e3d;
        }

        .img-box {
            background: #081a1a;
            min-width: 85px;
            height: 85px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .img-box img { width: 55px; height: auto; }

        .details { flex: 1; }
        .details h3 { margin: 0; font-size: 18px; }
        .price { color: var(--primary-green); float: right; font-size: 18px; font-weight: bold; }
        .desc { color: var(--text-gray); font-size: 13px; margin: 8px 0; }
        .label { font-size: 11px; color: var(--text-gray); text-transform: uppercase; }

        /* --- BUTTON LOGIC --- */
        .btns { 
            display: flex; 
            gap: 10px; 
            margin-top: 12px; 
            height: 40px; 
        }
        
        .btn {
            flex: 1; border-radius: 20px; border: none; padding: 10px;
            cursor: pointer; font-size: 13px; text-decoration: none;
            display: flex; align-items: center; justify-content: center;
        }
        .btn-ar { background: rgba(0, 210, 106, 0.1); color: var(--primary-green); border: 1px solid rgba(0, 210, 106, 0.3); }
        .btn-add { background: #0b3d26; color: var(--primary-green); border: 1px solid rgba(0, 210, 106, 0.2); }

        /* Inline Quantity Controller */
        .qty-controller {
            display: none; /* Hidden until item added */
            flex: 1;
            background: #0b3d26;
            border-radius: 20px;
            border: 1px solid var(--primary-green);
            align-items: center;
            justify-content: space-around;
            color: var(--primary-green);
            font-weight: bold;
        }
        .qty-controller button {
            background: none; border: none; color: var(--primary-green);
            font-size: 20px; cursor: pointer; padding: 0 10px;
        }

        /* --- Cart Styles --- */
        #cartOverlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--overlay); display: none; justify-content: center; align-items: flex-end;
            z-index: 1000;
        }
        .cart-modal {
            background: var(--card-bg); width: 100%; max-width: 500px;
            border-radius: 30px 30px 0 0; padding: 30px 20px;
            max-height: 80vh; overflow-y: auto;
        }
        .cart-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 0; border-bottom: 1px solid #1f2e3d;
        }
        .checkout-btn {
            background: var(--primary-green); color: black; width: 100%;
            padding: 16px; border-radius: 15px; border: none; font-weight: bold;
            margin-top: 20px; cursor: pointer;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div class="brand">
            <h1>Anni Cafe</h1>
            <p>DINE-IN ORDERING</p>
        </div>
        <div class="cart-wrapper" onclick="toggleCart(true)">
            🛒 <div id="cartBadge" class="cart-badge">0</div>
        </div>
    </header>

    <div class="categories">
        <button class="cat-btn active" onclick="filterMenu('All', this)">All</button>
        <button class="cat-btn" onclick="filterMenu('Appetizers', this)">Appetizers</button>
        <button class="cat-btn" onclick="filterMenu('Main Course', this)">Main Course</button>
        <button class="cat-btn" onclick="filterMenu('Desserts', this)">Desserts</button>
        <button class="cat-btn" onclick="filterMenu('Beverages', this)">Beverages</button>
    </div>

    <a href="/menu/new" class="admin-add-btn">
        <span style="color: var(--primary-green); font-size: 20px;">+</span> Add New Menu Item
    </a>

    <div id="menuList">
        <% items.forEach(item => { %>
        <div class="menu-card" data-category="<%= item.category %>" data-name="<%= item.name %>">
            <div class="img-box">
                <img src="<%= item.poster %>" alt="<%= item.name %>">
            </div>
            <div class="details">
                <span class="price">₹<%= item.price %></span>
                <h3><%= item.name %></h3>
                <p class="desc"><%= item.description %></p>
                <span class="label"><%= item.category %></span>
                <div class="btns">
                    <a href="<%= item.model %>" class="btn btn-ar">view AR</a>
                    
                    <button class="btn btn-add add-trigger" onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">Add to Cart</button>
                    
                    <div class="qty-controller">
                        <button onclick="updateCart('<%= item.name %>', <%= item.price %>, -1)">-</button>
                        <span class="qty-count">0</span>
                        <button onclick="updateCart('<%= item.name %>', <%= item.price %>, 1)">+</button>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>

<div id="cartOverlay" onclick="if(event.target == this) toggleCart(false)">
    <div class="cart-modal">
        <span onclick="toggleCart(false)" style="float:right; cursor:pointer;">Close ✕</span>
        <h2>Your Order</h2>
        <div id="cartItemsList"></div>
        <div style="display:flex; justify-content:space-between; margin-top:20px; font-size:20px; font-weight:bold;">
            <span>Total:</span>
            <span id="totalPrice" style="color: var(--primary-green);">₹0</span>
        </div>
        <button class="checkout-btn" onclick="confirmOrder()">Confirm Order</button>
    </div>
</div>

<script>
    let cart = [];

    // Core function to handle all + and - actions
    function updateCart(name, price, change) {
        const itemIndex = cart.findIndex(item => item.name === name);

        if (itemIndex > -1) {
            cart[itemIndex].qty += change;
            if (cart[itemIndex].qty <= 0) {
                cart.splice(itemIndex, 1);
            }
        } else if (change > 0) {
            cart.push({ name, price, qty: 1 });
        }

        syncUI();
    }

    // Refreshes both the Menu Cards and the Cart Modal
    function syncUI() {
        const badge = document.getElementById('cartBadge');
        let totalCount = 0;
        let totalPrice = 0;

        // 1. Update Menu Cards
        document.querySelectorAll('.menu-card').forEach(card => {
            const name = card.getAttribute('data-name');
            const item = cart.find(i => i.name === name);
            const addBtn = card.querySelector('.add-trigger');
            const qtyCtrl = card.querySelector('.qty-controller');
            const qtyLabel = card.querySelector('.qty-count');

            if (item) {
                addBtn.style.display = 'none';
                qtyCtrl.style.display = 'flex';
                qtyLabel.innerText = item.qty;
            } else {
                addBtn.style.display = 'flex';
                qtyCtrl.style.display = 'none';
            }
        });

        // 2. Update Cart Modal List
        const list = document.getElementById('cartItemsList');
        list.innerHTML = cart.length === 0 ? "<p>Cart is empty</p>" : "";
        
        cart.forEach(item => {
            totalCount += item.qty;
            totalPrice += (item.price * item.qty);
            list.innerHTML += `
                <div class="cart-item">
                    <div><b>${item.name}</b><br><small>₹${item.price}</small></div>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <button onclick="updateCart('${item.name}', ${item.price}, -1)" style="color:white; background:#1a2632; border:1px solid #2d3741; border-radius:5px; width:25px; cursor:pointer;">-</button>
                        <span>${item.qty}</span>
                        <button onclick="updateCart('${item.name}', ${item.price}, 1)" style="color:white; background:#1a2632; border:1px solid #2d3741; border-radius:5px; width:25px; cursor:pointer;">+</button>
                    </div>
                </div>`;
        });

        // 3. Update Badge and Total
        badge.innerText = totalCount;
        badge.style.display = totalCount > 0 ? "flex" : "none";
        document.getElementById('totalPrice').innerText = "₹" + totalPrice;
    }

    function toggleCart(show) {
        document.getElementById('cartOverlay').style.display = show ? "flex" : "none";
    }

    function confirmOrder() {
        if(cart.length === 0) return alert("Empty cart!");
        alert("Order placed! Total: " + document.getElementById('totalPrice').innerText);
        cart = [];
        syncUI();
        toggleCart(false);
    }

    function filterMenu(category, btn) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.menu-card').forEach(card => {
            const cat = card.getAttribute('data-category');
            card.style.display = (category === 'All' || cat === category) ? 'flex' : 'none';
        });
    }
</script>

</body>
</html>